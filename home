<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>To Have & Hold | Event Decor · Central Wisconsin</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,900;1,400;1,600&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --white:       #ffffff;
      --off-white:   #faf8f6;
      --surface:     #f4eeea;
      --rose:        #b86262;
      --rose-light:  #c47575;
      --rose-pale:   #ead4d4;
      --rose-wash:   #f5eaea;
      --ink:         #1e1714;
      --ink-mid:     #4a3d38;
      --ink-soft:    #7a6b63;
      --ink-faint:   #b0a099;
      --rule:        #e0d4cc;
      --sage:        #7a9e8e;
      --sage-light:  #9ab8aa;
      --sage-pale:   #ddeae5;
      --sage-wash:   #eef4f1;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--white);
      color: var(--ink);
      overflow-x: hidden;
    }

    /* ─── ANNOUNCEMENT ─── */
    .bar {
      background: var(--rose-wash);
      text-align: center;
      padding: 11px 24px;
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--rose);
    }
    .bar span { color: var(--ink-faint); margin: 0 10px; }

    /* ─── NAV ─── */
    nav {
      position: sticky;
      top: 0;
      z-index: 200;
      background: var(--white);
      border-bottom: 1px solid var(--rule);
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 72px;
      height: 110px;
    }
    .nav-logo {
      height: 96px;
      width: auto;
      display: block;
    }
    .nav-links {
      display: flex;
      gap: 40px;
      list-style: none;
    }
    .nav-links a {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-soft);
      text-decoration: none;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--ink); }
    .nav-cta {
      background: var(--rose) !important;
      color: white !important;
      padding: 11px 26px;
      letter-spacing: 0.16em !important;
      transition: background 0.2s !important;
    }
    .nav-cta:hover { background: var(--rose-light) !important; }

    /* ─── HERO ─── */
    #hero {
      min-height: 90vh;
      background: var(--white);
      display: grid;
      grid-template-columns: 1fr 1fr;
      border-bottom: 1px solid var(--rule);
    }
    .hero-left {
      padding: 88px 64px 88px 88px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }
    .hero-eyebrow {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 32px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .hero-eyebrow::before {
      content: '';
      width: 28px;
      height: 1px;
      background: var(--rose);
    }
    h1 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(42px, 4.5vw, 64px);
      font-weight: 700;
      line-height: 1.08;
      color: var(--ink);
      margin-bottom: 32px;
    }
    h1 em {
      font-style: italic;
      font-weight: 400;
      color: var(--rose);
    }
    .hero-body {
      font-size: 16px;
      font-weight: 300;
      line-height: 1.9;
      color: var(--ink-soft);
      max-width: 440px;
      margin-bottom: 48px;
    }
    .hero-ctas {
      display: flex;
      gap: 20px;
      align-items: center;
    }
    .btn-rose {
      background: var(--rose);
      color: white;
      font-family: 'Outfit', sans-serif;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      padding: 17px 40px;
      text-decoration: none;
      border: none;
      cursor: pointer;
      transition: background 0.2s, transform 0.15s;
      display: inline-block;
    }
    .btn-rose:hover { background: var(--rose-light); transform: translateY(-1px); }
    .btn-text {
      font-size: 13px;
      font-weight: 400;
      color: var(--ink-soft);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 7px;
      transition: color 0.2s;
    }
    .btn-text:hover { color: var(--ink); }
    .btn-text::after { content: '→'; }
    .hero-stats {
      display: flex;
      gap: 40px;
      margin-top: 56px;
      padding-top: 40px;
      border-top: 1px solid var(--rule);
    }
    .stat-val {
      font-family: 'Playfair Display', serif;
      font-size: 30px;
      font-weight: 700;
      color: var(--ink);
    }
    .stat-label {
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.1em;
      color: var(--ink-faint);
      margin-top: 4px;
    }
    .hero-right {
      background: var(--rose-wash);
      position: relative;
      display: flex;
      align-items: flex-end;
      justify-content: flex-start;
      padding: 48px;
    }
    .hero-card {
      position: relative;
      z-index: 2;
      background: var(--white);
      border-top: 2px solid var(--rose);
      padding: 28px 32px;
      min-width: 240px;
      box-shadow: 0 4px 32px rgba(30,23,20,0.06);
    }
    .hero-card-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 10px;
    }
    .hero-card-val {
      font-family: 'Playfair Display', serif;
      font-size: 18px;
      font-weight: 700;
      color: var(--ink);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .live-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #5aaa7a;
      animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    .hero-card-sub {
      font-size: 12px;
      color: var(--ink-faint);
      margin-top: 6px;
    }

    /* ─── PILL BAR ─── */
    .pill-bar {
      background: var(--surface);
      border-bottom: 1px solid var(--rule);
      padding: 18px 72px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 56px;
    }
    .pill-item {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--ink-soft);
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .pill-item::before {
      content: '';
      width: 4px; height: 4px;
      border-radius: 50%;
      background: var(--rose);
    }

    /* ─── SHARED SECTION ─── */
    .s-label {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.32em;
      text-transform: uppercase;
      color: var(--rose);
      margin-bottom: 14px;
    }
    .s-h2 {
      font-family: 'Playfair Display', serif;
      font-size: clamp(30px, 3vw, 46px);
      font-weight: 700;
      line-height: 1.1;
      color: var(--ink);
    }
    .s-h2 em { font-style: italic; font-weight: 400; }
    .s-rule {
      width: 36px; height: 1px;
      background: var(--rose);
      margin: 20px 0;
    }
    .s-body {
      font-size: 15px;
      font-weight: 300;
      line-height: 1.9;
      color: var(--ink-soft);
    }

    /* ─── SERVICES ─── */
    #services { padding: 104px 88px; background: var(--white); }
    .svc-header {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 48px;
      align-items: end;
      margin-bottom: 72px;
    }
    .svc-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
    }
    .svc-card {
      background: var(--white);
      padding: 52px 40px;
      position: relative;
      transition: background 0.3s;
    }
    .svc-card:hover { background: var(--rose-wash); }
    .svc-card::after {
      content: '';
      position: absolute;
      bottom: 0; left: 0; right: 0;
      height: 2px;
      background: var(--rose);
      transform: scaleX(0);
      transition: transform 0.35s ease;
      transform-origin: left;
    }
    .svc-card:hover::after { transform: scaleX(1); }
    .svc-num {
      font-family: 'Playfair Display', serif;
      font-size: 48px;
      font-weight: 700;
      color: var(--rose);
      opacity: 0.55;
      margin-bottom: 16px;
      line-height: 1;
      letter-spacing: -0.02em;
    }
    .svc-title {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 16px;
    }
    .svc-rule { width: 24px; height: 1px; background: var(--rose); margin-bottom: 18px; }
    .svc-desc {
      font-size: 14px;
      font-weight: 300;
      line-height: 1.85;
      color: var(--ink-soft);
      margin-bottom: 28px;
    }

    /* ─── PROOF ─── */
    #proof {
      background: var(--rose-wash);
      padding: 104px 88px;
      border-top: 1px solid var(--rose-pale);
      border-bottom: 1px solid var(--rose-pale);
    }
    .proof-layout {
      display: grid;
      grid-template-columns: 1fr 2fr;
      gap: 80px;
      align-items: start;
    }
    .proof-left .s-body { margin-bottom: 32px; }
    .stars { display: flex; gap: 3px; margin-bottom: 6px; }
    .star { color: #b5705a; font-size: 17px; }
    .rating-note { font-size: 12px; color: var(--ink-faint); }
    .t-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1px;
      background: var(--rose-pale);
    }
    .t-card { background: var(--white); padding: 40px; }
    .t-card.featured { grid-column: 1 / -1; background: var(--rose-pale); }
    .t-card.founder {
      background: var(--white);
      padding: 40px;
      border-top: 2px solid var(--rose);
    }
    .t-quote {
      font-family: 'Playfair Display', serif;
      font-size: 15px;
      font-style: italic;
      font-weight: 400;
      line-height: 1.85;
      color: var(--ink-mid);
      margin-bottom: 20px;
    }
    .t-card.featured .t-quote { font-size: 17px; color: var(--ink); }
    .t-card.founder .t-quote { font-size: 15px; color: var(--ink-mid); margin-bottom: 24px; }
    .t-name {
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--rose);
    }
    .founder-label {
      display: inline-block;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.24em;
      text-transform: uppercase;
      color: var(--rose);
      background: var(--rose-pale);
      padding: 4px 10px;
      margin-bottom: 20px;
    }

    /* ─── VALUES ─── */
    #values { background: var(--rose-wash); padding: 104px 88px; }
    .val-header { text-align: center; max-width: 560px; margin: 0 auto 64px; }
    .val-header .s-rule { margin: 20px auto; }
    .val-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
    }
    .val-item {
      background: var(--white);
      padding: 44px 32px;
      transition: background 0.25s;
    }
    .val-item:hover { background: var(--rose-wash); }
    .val-title {
      font-family: 'Playfair Display', serif;
      font-size: 17px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 12px;
    }
    .val-desc {
      font-size: 13px;
      font-weight: 300;
      line-height: 1.8;
      color: var(--ink-soft);
    }

    /* ─── CONSULT ─── */
    #consultation {
      background: var(--rose-wash);
      padding: 104px 88px;
      border-top: 1px solid var(--rule);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 88px;
      align-items: center;
    }
    .consult-bullets {
      list-style: none;
      margin: 28px 0 40px;
    }
    .consult-bullets li {
      display: flex;
      align-items: flex-start;
      gap: 14px;
      padding: 14px 0;
      border-bottom: 1px solid var(--rule);
      font-size: 14px;
      font-weight: 300;
      color: var(--ink-mid);
    }
    .consult-bullets li::before {
      content: '✓';
      color: var(--rose);
      font-size: 12px;
      font-weight: 600;
      margin-top: 1px;
    }
    .consult-card {
      background: var(--white);
      border-top: 2px solid var(--rose);
      padding: 52px 48px;
      box-shadow: 0 2px 24px rgba(30,23,20,0.05);
    }
    .consult-tag {
      display: inline-block;
      background: var(--rose-pale);
      color: var(--rose);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      padding: 7px 14px;
      margin-bottom: 24px;
    }
    .consult-title {
      font-family: 'Playfair Display', serif;
      font-size: 26px;
      font-weight: 700;
      color: var(--ink);
      margin-bottom: 6px;
    }
    .consult-meta {
      font-size: 12px;
      color: var(--ink-faint);
      margin-bottom: 24px;
    }
    .consult-body {
      font-size: 14px;
      font-weight: 300;
      line-height: 1.85;
      color: var(--ink-soft);
      margin-bottom: 32px;
    }
    .consult-items {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .consult-item {
      background: var(--rose-wash);
      padding: 13px 18px;
      font-size: 13px;
      color: var(--ink-mid);
    }

    /* ─── INQUIRY FORM ─── */
    #inquiry { background: var(--white); padding: 104px 88px; }
    .inq-wrap {
      display: grid;
      grid-template-columns: 1fr 1.5fr;
      gap: 88px;
      align-items: start;
      max-width: 1200px;
      margin: 0 auto;
    }
    .inq-left .s-body { margin-bottom: 40px; }
    .inq-perks {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .inq-perks li {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 14px;
      font-weight: 300;
      color: var(--ink-mid);
    }
    .inq-perks li::before {
      content: '';
      width: 6px; height: 6px;
      border-radius: 50%;
      background: var(--rose);
      flex-shrink: 0;
    }
    .form-card {
      border: 1px solid var(--rule);
      border-top: 2px solid var(--rose);
      padding: 52px 48px;
      background: var(--white);
    }
    .form-card .s-h2 { font-size: 24px; margin-bottom: 32px; }
    .form-note {
      text-align: center;
      font-size: 12px;
      color: var(--ink-faint);
      margin-top: 12px;
    }

    /* ─── NEWSLETTER ─── */
    #newsletter {
      background: var(--rose-pale);
      padding: 80px 88px;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 64px;
      align-items: center;
    }
    #newsletter .s-h2 { font-size: 32px; }
    #newsletter .s-body { margin-top: 16px; }
    .nl-form { display: flex; flex-direction: column; gap: 12px; }
    .nl-row { display: flex; gap: 12px; }
    .nl-form input {
      flex: 1;
      background: var(--white);
      border: 1px solid rgba(181,112,90,0.2);
      padding: 15px 20px;
      font-family: 'Outfit', sans-serif;
      font-size: 14px;
      color: var(--ink);
      outline: none;
      transition: border-color 0.2s;
    }
    .nl-form input::placeholder { color: var(--ink-faint); }
    .nl-form input:focus { border-color: var(--rose); }

    /* ─── FOOTER ─── */
    #thh-footer {
      background: var(--rose-pale);
      color: var(--ink);
      font-family: 'Outfit', sans-serif;
      padding: 64px 88px 36px;
    }
    .thh-ft-shell { max-width: 1240px; margin: 0 auto; }
    .thh-ft-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 48px;
      flex-wrap: wrap;
    }
    .thh-ft-brand {
      display: flex;
      align-items: center;
      gap: 24px;
      flex-wrap: wrap;
    }
    .thh-ft-logo {
      height: 56px;
      width: auto;
      display: block;
    }
    .thh-ft-tagline {
      margin: 0;
      font-size: 13px;
      font-weight: 300;
      line-height: 1.65;
      color: var(--ink-mid);
      max-width: 280px;
    }
    .thh-ft-tagline span {
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--rose);
    }
    .thh-ft-social {
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .thh-ft-social a {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      background: rgba(255,255,255,0.55);
      border: 1px solid rgba(184,98,98,0.25);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--rose);
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s, background 0.2s, transform 0.2s;
    }
    .thh-ft-social a:hover {
      background: var(--rose);
      border-color: var(--rose);
      color: var(--white);
      transform: translateY(-1px);
    }
    .thh-ft-social svg { display: block; }
    .thh-ft-divider {
      height: 1px;
      background: rgba(30,23,20,0.12);
      margin: 36px 0 22px;
    }
    .thh-ft-bottom {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 24px;
      flex-wrap: wrap;
    }
    .thh-ft-copyright {
      margin: 0;
      font-size: 12px;
      font-weight: 300;
      color: var(--ink-soft);
      letter-spacing: 0.02em;
    }
    .thh-ft-legal {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      align-items: center;
      gap: 14px;
    }
    .thh-ft-legal a {
      font-size: 11px;
      font-weight: 500;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--rose);
      text-decoration: none;
      transition: color 0.2s;
    }
    .thh-ft-legal a:hover { color: var(--ink); }
    .thh-ft-dot {
      width: 3px;
      height: 3px;
      border-radius: 50%;
      background: var(--rose);
      opacity: 0.55;
    }

    /* ─── REVEAL ─── */
    .reveal {
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 0.7s ease, transform 0.7s ease;
    }
    .reveal.in { opacity: 1; transform: none; }
    .d1 { transition-delay: 0.1s; }
    .d2 { transition-delay: 0.2s; }
    .d3 { transition-delay: 0.3s; }

    .hero-left > * { animation: hIn 0.75s ease both; }
    .hero-left > *:nth-child(1) { animation-delay: 0.05s; }
    .hero-left > *:nth-child(2) { animation-delay: 0.2s; }
    .hero-left > *:nth-child(3) { animation-delay: 0.35s; }
    .hero-left > *:nth-child(4) { animation-delay: 0.5s; }
    .hero-left > *:nth-child(5) { animation-delay: 0.62s; }
    @keyframes hIn {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: none; }
    }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 1024px) {
      nav { padding-left: 32px; padding-right: 32px; }
      #hero { grid-template-columns: 1fr; }
      .hero-left { padding: 80px 32px 48px; }
      .hero-right { min-height: 280px; }
      #services, #proof, #values, #consultation, #inquiry, #newsletter { padding: 72px 32px; }
      .svc-header, .proof-layout, #consultation, .inq-wrap, #newsletter { grid-template-columns: 1fr; gap: 40px; }
      .svc-grid, .val-grid { grid-template-columns: 1fr; }
      .t-grid { grid-template-columns: 1fr; }
      .t-card.featured { grid-column: auto; }
      .pill-bar { gap: 24px; padding: 16px 24px; flex-wrap: wrap; justify-content: center; }
    }
    @media (max-width: 768px) {
      #thh-footer { padding: 48px 24px 32px; }
      .thh-ft-top { flex-direction: column; align-items: flex-start; gap: 32px; }
      .thh-ft-brand { gap: 18px; }
      .thh-ft-logo { height: 48px; }
      .thh-ft-bottom { flex-direction: column; align-items: flex-start; gap: 18px; }
    }

    .social-bar {
      display: flex;
      align-items: center;
      gap: 16px;
    }
    .social-bar a {
      width: 38px;
      height: 38px;
      border-radius: 50%;
      border: 1px solid var(--rule);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--ink-soft);
      text-decoration: none;
      transition: border-color 0.2s, color 0.2s, background 0.2s;
    }
    .social-bar a:hover {
      border-color: var(--rose);
      color: var(--rose);
      background: var(--rose-wash);
