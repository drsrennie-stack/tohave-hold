<script>
  // Reveal on scroll
  const io = new IntersectionObserver(
    e => e.forEach(en => { if (en.isIntersecting) en.target.classList.add('in'); }),
    { threshold: 0.1 }
  );
  document.querySelectorAll('.reveal').forEach(el => io.observe(el));

  // ─── Kajabi form customization ───
  // The form renders via document.write during parse, so it's in the DOM by now.
  function customizeKajabiForm() {
    const btn = document.querySelector('.kajabi-form__btn');
    if (btn && btn.textContent.trim() === 'Subscribe') {
      btn.textContent = 'Keep Me In The Loop';
    }
    // Recalc iframe height when Kajabi shows its success state after submit
    const form = document.querySelector('#kajabi-form form');
    if (form) {
      form.addEventListener('submit', function() {
        // Fire a few delayed height checks to catch the post-submit layout
        setTimeout(sendHeight, 300);
        setTimeout(sendHeight, 1500);
        setTimeout(sendHeight, 3000);
      });
    }
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', customizeKajabiForm);
  } else {
    customizeKajabiForm();
  }

  // ─── reCAPTCHA badge remover (JS fallback for CSS hide) ───
  // Google's script can inject the badge after our CSS loads, so we actively
  // remove it. Branding stays in the trust line per Google's terms.
  function killRecaptchaBadge() {
    document.querySelectorAll('.grecaptcha-badge').forEach(el => el.remove());
  }
  // Watch the DOM for the badge being added and remove it the moment it appears
  const badgeObserver = new MutationObserver(killRecaptchaBadge);
  badgeObserver.observe(document.documentElement, { childList: true, subtree: true });
  // Also try on common lifecycle events
  killRecaptchaBadge();
  window.addEventListener('load', killRecaptchaBadge);
  setTimeout(killRecaptchaBadge, 500);
  setTimeout(killRecaptchaBadge, 2000);

  // ─── Iframe height sender for Kajabi embed ───
  function sendHeight() {
    if (window.parent === window) return;
    const height = document.documentElement.scrollHeight;
    window.parent.postMessage({ id: 'to-have-hold-stay-connected', height: height }, '*');
  }
  window.addEventListener('load', sendHeight);
  window.addEventListener('resize', sendHeight);
  const ro = new ResizeObserver(sendHeight);
  ro.observe(document.body);
</script>
